{
  "name": "sdkwork-manager-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "stop": "node ../sdkwork-specs/tools/stop-sdkwork-workspace-processes.mjs --workspace .",
    "dev": "pnpm --dir apps/sdkwork-manager-pc dev",
    "build": "pnpm --dir apps/sdkwork-manager-pc build",
    "start": "node scripts/dev/manager-start.mjs",
    "test": "pnpm test:node && pnpm test:vitest && cargo test --workspace",
    "test:node": "node --test tests/static/*.test.mjs tests/contract/*.test.mjs scripts/dev/*.test.mjs scripts/release/*.test.mjs",
    "test:vitest": "vitest run --config vitest.config.ts --configLoader native --pool vmThreads",
    "check": "pnpm run check:governance && pnpm run check:app-composition && pnpm api:envelope:check && pnpm api:check && pnpm route-manifest:check && pnpm sdk:check && pnpm db:validate && pnpm typecheck",
    "verify": "pnpm check && pnpm test:node && pnpm test:vitest && pnpm deploy:validate && pnpm topology:validate && pnpm build && pnpm gateway:validate:cloud && pnpm fmt:rust:check && cargo clippy --workspace --tests -- -D warnings && cargo test --workspace",
    "clean": "node -e \"console.log('Remove target/, node_modules/, dist/ manually or via CI cache reset')\"",
    "typecheck": "tsc --noEmit",
    "fmt:rust": "cargo fmt -p sdkwork-manager-gateway-assembly -p sdkwork-routes-manager-common -p sdkwork-platform-manager-service -p sdkwork-platform-manager-repository-sqlx -p sdkwork-routes-manager-app-api -p sdkwork-routes-manager-backend-api -p sdkwork-manager-database-host -p sdkwork-manager-service-host -p sdkwork-manager-standalone-gateway",
    "fmt:rust:check": "cargo fmt -p sdkwork-manager-gateway-assembly -p sdkwork-routes-manager-common -p sdkwork-platform-manager-service -p sdkwork-platform-manager-repository-sqlx -p sdkwork-routes-manager-app-api -p sdkwork-routes-manager-backend-api -p sdkwork-manager-database-host -p sdkwork-manager-service-host -p sdkwork-manager-standalone-gateway -- --check",
    "sdk:check": "node tools/manager_sdk_generate.mjs --check && pnpm sdk:rust:check",
    "sdk:rust:check": "cargo check --manifest-path sdks/sdkwork-manager-backend-sdk/sdkwork-manager-backend-sdk-rust/generated/server-openapi/Cargo.toml",
    "sdk:generate": "node tools/manager_sdk_generate.mjs",
    "api:materialize": "node tools/manager_openapi_export.mjs",
    "api:check": "node tools/manager_openapi_export.mjs --check",
    "api:envelope:check": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace ..",
    "admin:bootstrap:app": "node ../sdkwork-iam/scripts/bootstrap/bootstrap-app.mjs",
    "route-manifest:export": "node tools/manager_route_manifest_export.mjs",
    "route-manifest:check": "node tools/manager_route_manifest_export.mjs --check",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_manager_baseline.sql --module-id manager --owner manager-platform --prefixes platform_ --engines postgres",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "test:contract:database": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "gateway:package:cloud": "node ../sdkwork-app-topology/scripts/gateway-cloud-bundle.mjs bundle --root .",
    "gateway:validate:cloud": "node ../sdkwork-app-topology/scripts/gateway-cloud-bundle.mjs validate --root .",
    "gateway:sbom:cloud": "node scripts/release/cloud-config-sbom.mjs generate",
    "gateway:sbom:cloud:validate": "node scripts/release/cloud-config-sbom.mjs validate",
    "gateway:assembly:materialize": "node scripts/gateway/assembly-materialize.mjs",
    "gateway:assembly:validate": "node scripts/gateway/assembly-validate.mjs",
    "release:package": "node scripts/release/package-manager-server.mjs",
    "release:validate": "node scripts/release/validate-manager-release.mjs",
    "check:governance": "node ../sdkwork-specs/tools/check-agent-workflow-standard.mjs --root . && node ../sdkwork-specs/tools/check-repository-docs-standard.mjs --root .",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root .",
    "deploy:validate": "node ../sdkwork-specs/tools/check-deploy-standard.mjs"
  },
  "devDependencies": {
    "@sdkwork/iam-application-bootstrap": "workspace:*",
    "@sdkwork/utils": "workspace:*",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
