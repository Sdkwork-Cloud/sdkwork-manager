{
  "name": "sdkwork-manager-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "stop": "pnpm exec sdkwork-app stop",
    "dev": "pnpm dev:standalone",
    "build": "pnpm exec sdkwork-app build",
    "start": "pnpm dev:standalone",
    "test": "pnpm exec sdkwork-app test",
    "test:node": "node --test tests/static/*.test.mjs tests/contract/*.test.mjs scripts/dev/*.test.mjs scripts/release/*.test.mjs",
    "test:vitest": "vitest run --config vitest.config.ts --configLoader native --pool vmThreads",
    "check": "pnpm exec sdkwork-app check",
    "verify": "pnpm exec sdkwork-app verify",
    "clean": "pnpm exec sdkwork-app clean",
    "typecheck": "tsc --noEmit",
    "format": "cargo fmt -p sdkwork-api-manager-assembly -p sdkwork-routes-manager-common -p sdkwork-platform-manager-service -p sdkwork-platform-manager-repository-sqlx -p sdkwork-routes-manager-app-api -p sdkwork-routes-manager-backend-api -p sdkwork-manager-database-host -p sdkwork-manager-service-host -p sdkwork-api-manager-standalone-gateway",
    "format:check": "cargo fmt -p sdkwork-api-manager-assembly -p sdkwork-routes-manager-common -p sdkwork-platform-manager-service -p sdkwork-platform-manager-repository-sqlx -p sdkwork-routes-manager-app-api -p sdkwork-routes-manager-backend-api -p sdkwork-manager-database-host -p sdkwork-manager-service-host -p sdkwork-api-manager-standalone-gateway -- --check",
    "sdk:check": "node tools/manager_sdk_generate.mjs --check && pnpm sdk:rust:check",
    "sdk:rust:check": "cargo check --manifest-path sdks/sdkwork-manager-backend-sdk/sdkwork-manager-backend-sdk-rust/generated/server-openapi/Cargo.toml",
    "sdk:generate": "node tools/manager_sdk_generate.mjs",
    "api:materialize": "node tools/manager_openapi_export.mjs",
    "api:check": "node tools/manager_openapi_export.mjs --check",
    "api:envelope:check": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace ..",
    "admin:bootstrap:app": "node ../sdkwork-iam/scripts/bootstrap/bootstrap-app.mjs",
    "api:materialize:route-manifest": "node tools/manager_route_manifest_export.mjs",
    "api:check:route-manifest": "node tools/manager_route_manifest_export.mjs --check",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:pool:validate": "node ../sdkwork-specs/tools/check-process-shared-database-pool.mjs --root .",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_manager_baseline.sql --module-id manager --owner manager-platform --prefixes platform_ --engines postgres",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "db:postgres:plan": "node ../sdkwork-specs/tools/postgres/postgres-db-cli.mjs --mode plan --config .env.postgres --app-root .",
    "db:postgres:init": "node ../sdkwork-specs/tools/postgres/postgres-db-cli.mjs --mode init --config .env.postgres --app-root .",
    "test:contract:database": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "api:assembly:materialize": "node ../sdkwork-specs/tools/materialize-api-assembly.mjs --root .",
    "api:assembly:validate": "node ../sdkwork-specs/tools/validate-api-assembly.mjs --root .",
    "release:plan": "pnpm exec sdkwork-app release:plan",
    "release:plan:standalone": "pnpm exec sdkwork-app release:plan --deployment-profile standalone",
    "release:plan:cloud": "pnpm exec sdkwork-app release:plan --deployment-profile cloud",
    "release:build": "pnpm release:build:standalone",
    "release:build:standalone": "pnpm exec sdkwork-app release:build --target-id linux-x64-standalone-server-tar-gz",
    "release:build:cloud": "pnpm exec sdkwork-app release:build --target-id web-universal-cloud-browser-zip",
    "release:package": "pnpm release:package:standalone",
    "release:package:standalone": "pnpm exec sdkwork-app release:package --target-id linux-x64-standalone-server-tar-gz",
    "release:package:cloud": "pnpm exec sdkwork-app release:package --target-id web-universal-cloud-browser-zip",
    "release:validate": "pnpm release:validate:standalone",
    "release:validate:standalone": "pnpm exec sdkwork-app release:validate --target-id linux-x64-standalone-server-tar-gz",
    "release:validate:cloud": "pnpm exec sdkwork-app release:validate --target-id web-universal-cloud-browser-zip",
    "check:governance": "node ../sdkwork-specs/tools/check-agent-workflow-standard.mjs --root . && node ../sdkwork-specs/tools/check-repository-docs-standard.mjs --root .",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root .",
    "deploy:plan": "pnpm exec sdkwork-app deploy:plan",
    "deploy:plan:standalone": "pnpm exec sdkwork-app deploy:plan --profile standalone.production",
    "deploy:plan:cloud": "pnpm exec sdkwork-app deploy:plan --profile cloud.production",
    "deploy:apply": "pnpm exec sdkwork-app deploy:apply",
    "deploy:apply:standalone": "pnpm exec sdkwork-app deploy:apply --profile standalone.production --environment production",
    "deploy:apply:cloud": "pnpm exec sdkwork-app deploy:apply --profile cloud.production --environment production",
    "deploy:rollback": "pnpm exec sdkwork-app deploy:rollback",
    "deploy:rollback:standalone": "pnpm exec sdkwork-app deploy:rollback --profile standalone.production --environment production",
    "deploy:rollback:cloud": "pnpm exec sdkwork-app deploy:rollback --profile cloud.production --environment production",
    "deploy:validate": "pnpm exec sdkwork-app deploy:validate",
    "deploy:validate:standalone": "pnpm exec sdkwork-app deploy:validate --profile standalone.production",
    "deploy:validate:cloud": "pnpm exec sdkwork-app deploy:validate --profile cloud.production",
    "_sdkwork:build": "pnpm --dir apps/sdkwork-manager-pc build",
    "_sdkwork:test": "pnpm test:node && pnpm test:vitest && cargo test --workspace",
    "_sdkwork:check": "pnpm run check:governance && pnpm run check:app-composition && pnpm api:envelope:check && pnpm api:check && pnpm api:check:route-manifest && pnpm sdk:check && pnpm db:validate && pnpm db:pool:validate && pnpm typecheck",
    "_sdkwork:verify": "pnpm check && pnpm test:node && pnpm test:vitest && pnpm deploy:validate && pnpm topology:validate && pnpm build && pnpm api:assembly:validate && pnpm format:check && cargo clippy --workspace --tests -- -D warnings && cargo test --workspace",
    "_sdkwork:clean": "node -e \"console.log('Remove target/, node_modules/, dist/ manually or via CI cache reset')\"",
    "_sdkwork:gateway:standalone": "node scripts/dev/manager-start.mjs",
    "_sdkwork:client:browser": "pnpm --dir apps/sdkwork-manager-pc dev",
    "_sdkwork:release:package:standalone": "node scripts/release/package-manager-server.mjs",
    "_sdkwork:release:validate:standalone": "node scripts/release/validate-manager-release.mjs",
    "_sdkwork:release:package:cloud": "pnpm build && node scripts/release/browser-release-sbom.mjs generate",
    "_sdkwork:release:validate:cloud": "node scripts/release/browser-release-sbom.mjs validate",
    "dev:standalone": "pnpm exec sdkwork-app dev --deployment-profile standalone",
    "dev:cloud": "pnpm exec sdkwork-app dev --deployment-profile cloud",
    "_sdkwork:release:build:standalone": "pnpm exec sdkwork-app release:build --target-id linux-x64-standalone-server-tar-gz",
    "_sdkwork:release:build:cloud": "pnpm exec sdkwork-app release:build --target-id web-universal-cloud-browser-zip",
    "_sdkwork:deploy:plan:standalone": "pnpm exec sdkwork-app deploy:plan --profile standalone.production",
    "_sdkwork:deploy:plan:cloud": "pnpm exec sdkwork-app deploy:plan --profile cloud.production",
    "_sdkwork:deploy:apply:standalone": "pnpm exec sdkwork-app deploy:apply --profile standalone.production --environment production",
    "_sdkwork:deploy:apply:cloud": "pnpm exec sdkwork-app deploy:apply --profile cloud.production --environment production",
    "_sdkwork:deploy:rollback:standalone": "pnpm exec sdkwork-app deploy:rollback --profile standalone.production --environment production",
    "_sdkwork:deploy:rollback:cloud": "pnpm exec sdkwork-app deploy:rollback --profile cloud.production --environment production",
    "_sdkwork:deploy:validate:standalone": "pnpm exec sdkwork-app deploy:validate --profile standalone.production",
    "_sdkwork:deploy:validate:cloud": "pnpm exec sdkwork-app deploy:validate --profile cloud.production"
  },
  "devDependencies": {
    "@sdkwork/iam-application-bootstrap": "workspace:*",
    "@sdkwork/utils": "workspace:*",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "@sdkwork/app-topology": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
