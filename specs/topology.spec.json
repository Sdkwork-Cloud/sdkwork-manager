{
  "schemaVersion": 5,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-manager",
  "archetype": "application-http-gateway",
  "profileRoot": "etc/deployments",
  "profilePattern": "{deploymentProfile}.{environment}.env",
  "vocabulary": {
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    },
    "environment": {
      "allowed": [
        "development",
        "production"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.development",
    "productionProfileId": "cloud.production",
    "desktopBuildProfileId": "standalone.production",
    "gatewayBind": "127.0.0.1:18092"
  },
  "profileFiles": {
    "standalone.development": "etc/deployments/standalone.development.env",
    "standalone.production": "etc/deployments/standalone.production.env",
    "cloud.development": "etc/deployments/cloud.development.env",
    "cloud.production": "etc/deployments/cloud.production.env"
  },
  "envKeys": {
    "deploymentProfile": "SDKWORK_MANAGER_DEPLOYMENT_PROFILE",
    "environment": "SDKWORK_MANAGER_ENVIRONMENT",
    "profileId": "SDKWORK_MANAGER_PROFILE_ID",
    "clientDeploymentProfile": "VITE_SDKWORK_MANAGER_DEPLOYMENT_PROFILE",
    "standaloneGatewayBind": "SDKWORK_MANAGER_APPLICATION_PUBLIC_INGRESS_BIND",
    "clientApiGatewayBaseUrl": "VITE_SDKWORK_MANAGER_PLATFORM_API_GATEWAY_HTTP_URL",
    "apiGatewayBaseUrl": "SDKWORK_MANAGER_PLATFORM_API_GATEWAY_HTTP_URL"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_MANAGER_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_MANAGER_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_MANAGER_APPLICATION_PUBLIC_HTTP_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": [
        "http"
      ],
      "httpUrlEnv": "SDKWORK_MANAGER_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_MANAGER_PLATFORM_API_GATEWAY_HTTP_URL"
    }
  },
  "cloudPublicHosts": {
    "application.public-ingress": {
      "httpHost": "manager.sdkwork.com"
    },
    "platform.api-gateway": {
      "httpHost": "api.sdkwork.com"
    }
  },
  "database": {
    "appPrefix": "SDKWORK_MANAGER"
  },
  "components": {
    "applicationServer": {
      "crate": "sdkwork-api-manager-standalone-gateway",
      "binary": "manager-server"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.development": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-api-manager-standalone-gateway",
            "binary": "manager-server",
            "script": "_sdkwork:gateway:standalone",
            "required": true,
            "role": "api-standalone-gateway"
          },
          {
            "id": "manager-pc-browser",
            "role": "client",
            "script": "_sdkwork:client:browser",
            "bindEnv": "SDKWORK_MANAGER_PC_DEV_BIND",
            "runtimeTargets": [
              "browser"
            ],
            "clientArchitectures": [
              "pc-web"
            ]
          }
        ],
        "managedResources": [
          {
            "id": "manager-wsl-postgres-portproxy",
            "driver": "windows-wsl-tcp-portproxy",
            "enabledEnv": "SDKWORK_MANAGER_WSL_POSTGRES_PORTPROXY_ENABLED",
            "listenAddressEnv": "SDKWORK_CLAW_DATABASE_HOST",
            "listenAddress": "127.0.0.1",
            "listenPortEnv": "SDKWORK_CLAW_DATABASE_PORT",
            "listenPort": 5432,
            "distributionEnv": "SDKWORK_MANAGER_WSL_DISTRIBUTION",
            "distribution": "Ubuntu-22.04"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      },
      "cloud.development": {
        "processes": [
          {
            "id": "manager-pc-browser",
            "role": "client",
            "script": "_sdkwork:client:browser",
            "bindEnv": "SDKWORK_MANAGER_PC_DEV_BIND",
            "runtimeTargets": [
              "browser"
            ],
            "clientArchitectures": [
              "pc-web"
            ]
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      },
      "cloud.production": {
        "processes": [],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      },
      "standalone.production": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-api-manager-standalone-gateway",
            "binary": "manager-server",
            "required": true,
            "role": "api-standalone-gateway"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      }
    }
  },
  "packaging": {
    "targets": [
      {
        "id": "linux-x64-standalone-server-tar-gz",
        "profile": "server",
        "platform": "linux",
        "architecture": "x64",
        "formats": [
          "tar.gz"
        ],
        "runner": "ubuntu-24.04",
        "outputGlob": "artifacts/release/**/*",
        "deploymentProfile": "standalone",
        "runtimeTarget": "server"
      }
    ]
  }
}
