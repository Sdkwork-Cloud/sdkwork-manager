{
  "schemaVersion": "2026-06-06.sdkwork.workflow.v1",
  "app": {
    "id": "sdkwork-manager",
    "name": "SDKWork Manager",
    "repository": "Sdkwork-Cloud/sdkwork-manager",
    "sourcePath": "."
  },
  "release": {
    "artifactPrefix": "sdkwork-manager",
    "defaultVersion": "0.1.0",
    "changelog": {
      "source": "auto",
      "maxCommitSubjects": 50
    }
  },
  "dependencies": [
    {
      "id": "sdkwork-appbase",
      "repository": "Sdkwork-Cloud/sdkwork-appbase",
      "ref": "main",
      "refInput": "SDKWORK_APPBASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-web-framework",
      "repository": "Sdkwork-Cloud/sdkwork-web-framework",
      "ref": "main",
      "refInput": "SDKWORK_WEB_FRAMEWORK_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-database",
      "repository": "Sdkwork-Cloud/sdkwork-database",
      "ref": "main",
      "refInput": "SDKWORK_DATABASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-utils",
      "repository": "Sdkwork-Cloud/sdkwork-utils",
      "ref": "main",
      "refInput": "SDKWORK_UTILS_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-sdk-generator",
      "repository": "Sdkwork-Cloud/sdkwork-sdk-generator",
      "ref": "main",
      "refInput": "SDKWORK_SDK_GENERATOR_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-app-topology",
      "repository": "Sdkwork-Cloud/sdkwork-app-topology",
      "ref": "main",
      "refInput": "SDKWORK_APP_TOPOLOGY_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-iam",
      "repository": "Sdkwork-Cloud/sdkwork-iam",
      "ref": "main",
      "refInput": "SDKWORK_IAM_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-drive",
      "repository": "Sdkwork-Cloud/sdkwork-drive",
      "ref": "main",
      "refInput": "SDKWORK_DRIVE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-payment",
      "repository": "Sdkwork-Cloud/sdkwork-payment",
      "ref": "main",
      "refInput": "SDKWORK_PAYMENT_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-order",
      "repository": "Sdkwork-Cloud/sdkwork-order",
      "ref": "main",
      "refInput": "SDKWORK_ORDER_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-promotion",
      "repository": "Sdkwork-Cloud/sdkwork-promotion",
      "ref": "main",
      "refInput": "SDKWORK_PROMOTION_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-membership",
      "repository": "Sdkwork-Cloud/sdkwork-membership",
      "ref": "main",
      "refInput": "SDKWORK_MEMBERSHIP_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-core",
      "repository": "Sdkwork-Cloud/sdkwork-core",
      "ref": "main",
      "refInput": "SDKWORK_CORE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-ui",
      "repository": "Sdkwork-Cloud/sdkwork-ui",
      "ref": "main",
      "refInput": "SDKWORK_UI_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-sdk-commons",
      "repository": "Sdkwork-Cloud/sdkwork-sdk-commons",
      "ref": "main",
      "refInput": "SDKWORK_SDK_COMMONS_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-specs",
      "repository": "Sdkwork-Cloud/sdkwork-specs",
      "ref": "main",
      "refInput": "SDKWORK_SPECS_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    }
  ],
  "toolchains": {
    "node": "22",
    "pnpm": "10.33.0",
    "rust": "stable"
  },
  "lifecycle": {
    "install": [
      {
        "name": "Install workspace dependencies",
        "shell": "pwsh",
        "run": "pnpm install --no-frozen-lockfile"
      }
    ],
    "build": [
      {
        "name": "Run SDKWork Manager contract checks",
        "shell": "pwsh",
        "run": "pnpm run verify"
      }
    ],
    "package": [
      {
        "name": "Package Manager release target",
        "shell": "node",
        "run": "import { runManagerReleasePhase } from './scripts/release/manager-release-lifecycle.mjs'; await runManagerReleasePhase('package');"
      }
    ],
    "sbom": [
      {
        "name": "Generate or verify Manager release SBOM",
        "shell": "node",
        "run": "import { runManagerReleasePhase } from './scripts/release/manager-release-lifecycle.mjs'; await runManagerReleasePhase('sbom');"
      }
    ],
    "validate": [
      {
        "name": "Validate Manager release target",
        "shell": "node",
        "run": "import { runManagerReleasePhase } from './scripts/release/manager-release-lifecycle.mjs'; await runManagerReleasePhase('validate');"
      }
    ]
  },
  "targets": [
    {
      "id": "linux-x64-standalone-server-tar-gz",
      "profile": "server",
      "platform": "linux",
      "architecture": "x64",
      "formats": ["tar.gz"],
      "runner": "ubuntu-24.04",
      "outputGlobs": ["artifacts/release/**/*"],
      "deploymentProfile": "standalone",
      "runtimeTarget": "server"
    },
    {
      "id": "web-universal-cloud-browser-zip",
      "profile": "browser",
      "platform": "web",
      "architecture": "universal",
      "formats": ["zip"],
      "runner": "ubuntu-24.04",
      "outputGlobs": [
        "apps/sdkwork-manager-pc/dist/**",
        "artifacts/release/sbom/web-universal-cloud-browser-zip.sbom.json"
      ],
      "deploymentProfile": "cloud",
      "runtimeTarget": "browser"
    }
  ],
  "security": {
    "artifactAttestations": true,
    "sbomRequired": true,
    "signingRequired": false
  },
  "publish": {
    "workflowArtifact": true,
    "githubRelease": false,
    "retentionDays": 30
  }
}
