# SDKWork Manager local PostgreSQL development profile.
# Copy this file to .env.postgres and adjust it for the PostgreSQL cluster
# exposed by WSL. Do not commit .env.postgres.
#
# PostgreSQL connection identity is unified across SDKWork applications.
# See ../sdkwork-specs/ENVIRONMENT_SPEC.md section 7.1.

SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_PASSWORD=sdkworkdev123
SDKWORK_CLAW_DATABASE_SSL_MODE=disable
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=10
SDKWORK_DATABASE_TEMPORARY_ANY_POOL_EXCEPTION=true

# The Manager development launcher can refresh the Windows portproxy target
# after WSL receives a new NAT address. This requires an elevated terminal.
SDKWORK_MANAGER_WSL_POSTGRES_PORTPROXY_ENABLED=true
SDKWORK_MANAGER_WSL_DISTRIBUTION=Ubuntu-22.04

# Administrative credentials are used only by database lifecycle commands
# that create or upgrade the local development database.
SDKWORK_CLAW_DATABASE_ADMIN_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_ADMIN_PORT=5432
SDKWORK_CLAW_DATABASE_ADMIN_USERNAME=postgres
SDKWORK_CLAW_DATABASE_ADMIN_PASSWORD=postgres_admin_pass
SDKWORK_CLAW_DATABASE_ADMIN_DATABASE=postgres
SDKWORK_CLAW_DATABASE_ADMIN_SSL_MODE=disable
