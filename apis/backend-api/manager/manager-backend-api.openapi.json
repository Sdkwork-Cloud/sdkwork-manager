{
  "openapi": "3.1.2",
  "info": {
    "title": "SDKWork Manager Backend API",
    "version": "1.0.0",
    "description": "Backend/admin contract for SDKWork platform manager capability.",
    "x-sdkwork-api-authority": "sdkwork-manager-backend-api",
    "x-sdkwork-sdk-family": "sdkwork-manager-backend-sdk",
    "x-sdkwork-owner": "sdkwork-manager"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:18092",
      "description": "Local sdkwork-manager runtime"
    }
  ],
  "security": [
    {
      "AuthToken": [],
      "AccessToken": []
    }
  ],
  "paths": {
    "/backend/v3/api/manager/preferences": {
      "get": {
        "operationId": "manager.preferences.admin.list",
        "summary": "List manager preferences for tenant administration",
        "tags": [
          "manager"
        ],
        "x-sdkwork-api-surface": "backend-api",
        "x-sdkwork-request-context": "WebRequestContext",
        "security": [
          {
            "AuthToken": [],
            "AccessToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "Preference summaries",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SdkWorkApiResponse"
                    },
                    {
                      "type": "object",
                      "required": [
                        "data"
                      ],
                      "properties": {
                        "data": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": [
                            "items",
                            "pageInfo"
                          ],
                          "properties": {
                            "items": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "userId": {
                                    "type": "string",
                                    "format": "uuid"
                                  },
                                  "theme": {
                                    "type": "string"
                                  },
                                  "pinnedCount": {
                                    "type": "integer"
                                  }
                                },
                                "required": [
                                  "userId",
                                  "theme",
                                  "pinnedCount"
                                ]
                              }
                            },
                            "pageInfo": {
                              "$ref": "#/components/schemas/PageInfo"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid credentials",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server failure",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        }
      }
    },
    "/backend/v3/api/manager/commercial_entitlements/current": {
      "get": {
        "operationId": "manager.commercialEntitlements.current.retrieve",
        "summary": "Retrieve the current tenant application commercial entitlement snapshot",
        "tags": ["manager"],
        "x-sdkwork-api-surface": "backend-api",
        "x-sdkwork-request-context": "WebRequestContext",
        "x-sdkwork-permission": "manager.entitlements.read",
        "security": [{ "AuthToken": [], "AccessToken": [] }],
        "responses": {
          "200": {
            "description": "Current tenant application commercial entitlement snapshot",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CommercialEntitlementResponse" }
              }
            }
          },
          "401": {
            "description": "Missing or invalid credentials",
            "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } } }
          },
          "403": {
            "description": "Missing commercial entitlement read permission",
            "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } } }
          },
          "500": {
            "description": "Unexpected server failure",
            "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } } }
          }
        }
      },
      "put": {
        "operationId": "manager.commercialEntitlements.current.update",
        "summary": "Replace the current tenant application commercial entitlement snapshot",
        "tags": ["manager"],
        "x-sdkwork-api-surface": "backend-api",
        "x-sdkwork-request-context": "WebRequestContext",
        "x-sdkwork-permission": "manager.entitlements.manage",
        "security": [{ "AuthToken": [], "AccessToken": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateCommercialEntitlementRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated tenant application commercial entitlement snapshot",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CommercialEntitlementResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid commercial entitlement input",
            "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } } }
          },
          "401": {
            "description": "Missing or invalid credentials",
            "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } } }
          },
          "403": {
            "description": "Missing commercial entitlement management permission",
            "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } } }
          },
          "409": {
            "description": "Commercial entitlement snapshot version conflict",
            "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } } }
          },
          "500": {
            "description": "Unexpected server failure",
            "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } } }
          }
        }
      }
    },
    "/backend/v3/api/manager/commercial_entitlements/verify": {
      "post": {
        "operationId": "manager.commercialEntitlements.verify",
        "summary": "Evaluate one tenant application commercial entitlement",
        "description": "Server-side enforcement endpoint for trusted gateway and business-service identities.",
        "tags": ["manager"],
        "x-sdkwork-api-surface": "backend-api",
        "x-sdkwork-request-context": "WebRequestContext",
        "x-sdkwork-permission": "manager.entitlements.enforce",
        "security": [{ "AuthToken": [], "AccessToken": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CommercialEntitlementDecisionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Commercial entitlement enforcement decision",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CommercialEntitlementDecisionResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid entitlement key",
            "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } } }
          },
          "401": {
            "description": "Missing or invalid service credentials",
            "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } } }
          },
          "403": {
            "description": "Missing commercial entitlement enforcement permission",
            "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } } }
          },
          "500": {
            "description": "Unexpected server failure",
            "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } } }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "AuthToken": {
        "type": "http",
        "scheme": "bearer"
      },
      "AccessToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Access-Token"
      }
    },
    "schemas": {
      "SdkWorkApiResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "data",
          "traceId"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32",
            "enum": [
              0
            ],
            "default": 0,
            "minimum": 0,
            "maximum": 0
          },
          "data": {
            "description": "Operation-specific payload typed per response schema."
          },
          "traceId": {
            "type": "string",
            "format": "uuid",
            "description": "Server-owned request correlation id."
          }
        }
      },
      "SdkWorkResourceData": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item"
        ],
        "properties": {
          "item": {
            "type": "object",
            "additionalProperties": true,
            "description": "Typed domain resource for the operation."
          }
        }
      },
      "SdkWorkPageData": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "items",
          "pageInfo"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "pageInfo": {
            "$ref": "#/components/schemas/PageInfo"
          }
        }
      },
      "SdkWorkCommandData": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "accepted"
        ],
        "properties": {
          "accepted": {
            "type": "boolean",
            "const": true
          },
          "resourceId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "PageInfo": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mode"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "offset",
              "cursor"
            ]
          },
          "page": {
            "type": "integer",
            "minimum": 1
          },
          "pageSize": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200
          },
          "totalItems": {
            "type": "string",
            "pattern": "^[0-9]+$"
          },
          "totalPages": {
            "type": "integer",
            "minimum": 0
          },
          "nextCursor": {
            "type": [
              "string",
              "null"
            ]
          },
          "hasMore": {
            "type": "boolean"
          }
        }
      },
      "SdkWorkPlatformErrorCode": {
        "type": "integer",
        "format": "int32",
        "minimum": 40001,
        "maximum": 79999,
        "description": "Platform or domain error code per API_SPEC.md §15.3."
      },
      "ProblemDetail": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "type",
          "title",
          "status",
          "code",
          "traceId"
        ],
        "properties": {
          "type": {
            "type": "string",
            "format": "uri-reference"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "minimum": 100,
            "maximum": 599
          },
          "detail": {
            "type": "string"
          },
          "instance": {
            "type": "string"
          },
          "code": {
            "$ref": "#/components/schemas/SdkWorkPlatformErrorCode"
          },
          "traceId": {
            "type": "string",
            "format": "uuid",
            "description": "Server-owned request correlation id."
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FieldError"
            }
          }
        }
      },
      "FieldError": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "field",
          "message"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "code": {
            "type": "integer",
            "format": "int32",
            "minimum": 40011,
            "maximum": 40099
          }
        }
      },
      "CommercialEntitlementTier": {
        "type": "string",
        "enum": ["foundation", "standard", "professional", "enterprise"]
      },
      "CommercialEntitlementStatus": {
        "type": "string",
        "enum": ["active", "suspended", "expired"]
      },
      "CommercialEntitlementItem": {
        "type": "object",
        "additionalProperties": false,
        "required": ["appId", "entitlementKeys", "tier", "status", "version", "updatedAt"],
        "properties": {
          "appId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9._-]+$"
          },
          "entitlementKeys": {
            "type": "array",
            "maxItems": 100,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 160,
              "pattern": "^[A-Za-z0-9._-]+$"
            }
          },
          "tier": { "$ref": "#/components/schemas/CommercialEntitlementTier" },
          "status": { "$ref": "#/components/schemas/CommercialEntitlementStatus" },
          "validUntil": { "type": ["string", "null"], "format": "date-time" },
          "version": { "type": "string", "pattern": "^[0-9]+$" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "UpdateCommercialEntitlementRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["appId", "entitlementKeys", "tier", "status", "expectedVersion"],
        "properties": {
          "appId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9._-]+$"
          },
          "entitlementKeys": {
            "type": "array",
            "maxItems": 100,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 160,
              "pattern": "^[A-Za-z0-9._-]+$"
            }
          },
          "tier": { "$ref": "#/components/schemas/CommercialEntitlementTier" },
          "status": { "$ref": "#/components/schemas/CommercialEntitlementStatus" },
          "validUntil": { "type": ["string", "null"], "format": "date-time" },
          "expectedVersion": { "type": "string", "pattern": "^[0-9]+$" }
        }
      },
      "CommercialEntitlementDecisionRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["appId", "entitlementKey"],
        "properties": {
          "appId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9._-]+$"
          },
          "entitlementKey": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160,
            "pattern": "^[A-Za-z0-9._-]+$"
          }
        }
      },
      "CommercialEntitlementDecisionItem": {
        "type": "object",
        "additionalProperties": false,
        "required": ["accepted", "allowed", "appId", "entitlementKey", "reason", "tier", "snapshotVersion", "status"],
        "properties": {
          "accepted": { "type": "boolean", "const": true },
          "allowed": { "type": "boolean" },
          "appId": { "type": "string" },
          "entitlementKey": { "type": "string" },
          "reason": {
            "type": "string",
            "enum": ["entitlement_active", "entitlement_missing", "snapshot_inactive", "snapshot_expired"]
          },
          "tier": { "$ref": "#/components/schemas/CommercialEntitlementTier" },
          "snapshotVersion": { "type": "string", "pattern": "^[0-9]+$" },
          "status": { "type": "string", "enum": ["allowed", "denied"] },
          "validUntil": { "type": ["string", "null"], "format": "date-time" }
        }
      },
      "CommercialEntitlementResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/SdkWorkApiResponse" },
          {
            "type": "object",
            "required": ["data"],
            "properties": {
              "data": {
                "type": "object",
                "additionalProperties": false,
                "required": ["item"],
                "properties": {
                  "item": { "$ref": "#/components/schemas/CommercialEntitlementItem" }
                }
              }
            }
          }
        ]
      },
      "CommercialEntitlementDecisionResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/SdkWorkApiResponse" },
          {
            "type": "object",
            "required": ["data"],
            "properties": {
              "data": { "$ref": "#/components/schemas/CommercialEntitlementDecisionItem" }
            }
          }
        ]
      },
      "SdkWorkResourceResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SdkWorkApiResponse"
          },
          {
            "type": "object",
            "required": [
              "data"
            ],
            "properties": {
              "data": {
                "$ref": "#/components/schemas/SdkWorkResourceData"
              }
            }
          }
        ]
      },
      "SdkWorkListResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SdkWorkApiResponse"
          },
          {
            "type": "object",
            "required": [
              "data"
            ],
            "properties": {
              "data": {
                "$ref": "#/components/schemas/SdkWorkPageData"
              }
            }
          }
        ]
      },
      "SdkWorkCommandResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SdkWorkApiResponse"
          },
          {
            "type": "object",
            "required": [
              "data"
            ],
            "properties": {
              "data": {
                "$ref": "#/components/schemas/SdkWorkCommandData"
              }
            }
          }
        ]
      }
    }
  }
}
