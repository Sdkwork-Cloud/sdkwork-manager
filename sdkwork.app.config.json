{
  "schemaVersion": 3,
  "kind": "sdkwork.app",
  "app": {
    "key": "sdkwork-manager",
    "name": "SDKWork Manager",
    "displayName": "SDKWork Manager",
    "description": "SDKWork platform manager admin console for operator workflows, preferences, and tenant administration.",
    "vendor": "SDKWork",
    "officialWebsiteUrl": "https://sdkwork.com/apps/sdkwork-manager",
    "appType": "APP_REACT",
    "versionSource": "package.json",
    "identifiers": {
      "desktopAppId": "com.sdkwork.manager.pc.desktop",
      "containerImage": "registry.sdkwork.com/apps/sdkwork-manager"
    }
  },
  "backend": {
    "profileKey": "backend-root-admin",
    "ownerMode": "tenant",
    "grantMode": "current",
    "platform": "WEB",
    "appId": "sdkwork-manager-pc",
    "accessTokenPermissionScope": [
      "iam.users.read",
      "iam.organizations.read",
      "iam.roles.read",
      "iam.permissions.read"
    ]
  },
  "runtime": {
    "family": "web",
    "framework": "react",
    "runtimes": [
      "WEB",
      "BROWSER"
    ],
    "deliveryModes": [
      "WEB_URL"
    ],
    "supportedDeploymentProfiles": [
      "standalone",
      "cloud"
    ],
    "defaultDeploymentProfile": "cloud"
  },
  "envBindings": {
    "schemaVersion": 2,
    "family": "web",
    "runtime": "vite-react",
    "preset": "vite-react-standard",
    "outputStrategy": "dotenv-overlay",
    "platform": "web",
    "ownerMode": "tenant",
    "grantMode": "current",
    "tokenPlatform": "WEB",
    "variables": [
      {
        "name": "VITE_SDKWORK_MANAGER_APPLICATION_PUBLIC_HTTP_URL",
        "required": true,
        "tracked": true,
        "surface": "app-api",
        "sdkFamily": "sdkwork-manager-app-sdk"
      },
      {
        "name": "VITE_SDKWORK_MANAGER_PLATFORM_API_GATEWAY_HTTP_URL",
        "required": true,
        "tracked": true,
        "surface": "backend-api",
        "sdkFamily": "sdkwork-iam-backend-sdk"
      },
      {
        "name": "VITE_SDKWORK_MANAGER_VITE_DEV_PROXY_ENABLED",
        "required": false,
        "tracked": true
      },
      {
        "name": "VITE_SDKWORK_MANAGER_ENVIRONMENT",
        "required": true,
        "tracked": true
      },
      {
        "name": "VITE_SDKWORK_MANAGER_DEPLOYMENT_PROFILE",
        "required": true,
        "tracked": true
      }
    ],
    "sdkBaseUrls": {
      "appApiBaseUrlKey": "VITE_SDKWORK_MANAGER_APPLICATION_PUBLIC_HTTP_URL",
      "backendApiBaseUrlKey": "VITE_SDKWORK_MANAGER_APPLICATION_PUBLIC_HTTP_URL",
      "dependencySdkBaseUrlKeys": {
        "sdkwork-iam-app-sdk": {
          "appApiBaseUrlKey": "VITE_SDKWORK_MANAGER_PLATFORM_API_GATEWAY_HTTP_URL"
        },
        "sdkwork-iam-backend-sdk": {
          "backendApiBaseUrlKey": "VITE_SDKWORK_MANAGER_PLATFORM_API_GATEWAY_HTTP_URL"
        }
      }
    }
  },
  "media": {
    "icons": {
      "primary": {
        "id": "sdkwork-manager-primary-icon",
        "type": "ICON",
        "purpose": "PRIMARY",
        "url": "https://cdn.sdkwork.com/apps/sdkwork-manager/assets/icon-1024.png",
        "platform": "WEB",
        "locale": "en-US",
        "width": 1024,
        "height": 1024,
        "format": "PNG",
        "enabled": true
      },
      "platform": []
    },
    "screenshots": [],
    "previews": [],
    "metadata": {
      "assetVersion": "0.1.0",
      "defaultLocale": "en-US"
    }
  },
  "publish": {
    "status": "ACTIVE",
    "platforms": [
      "WEB",
      "BROWSER"
    ],
    "installPlatforms": [
      "WEB"
    ],
    "config": {
      "workspaceRoot": "sdkwork-manager",
      "managedBy": "sdkwork-manager-workspace"
    }
  },
  "environments": {
    "development": {
      "accessUrl": "http://127.0.0.1:18092",
      "deployUrl": "http://127.0.0.1:18092",
      "deployEnv": "dev"
    },
    "production": {
      "runtimeProfile": "cloud.split-services.production"
    }
  },
  "artifacts": {
    "installConfig": {
      "packages": []
    }
  },
  "release": {
    "channel": "stable",
    "governance": "standard"
  },
  "security": {
    "dataClassification": "internal",
    "requiresAuthentication": true
  },
  "devApp": {
    "sourceRoot": "apps/sdkwork-manager-pc"
  },
  "metadata": {
    "standardOwner": "sdkwork-specs",
    "initializedAt": "2026-06-21T00:00:00.000Z"
  }
}
