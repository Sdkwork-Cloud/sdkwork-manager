# cloud.split-services.production
SDKWORK_MANAGER_DEPLOYMENT_PROFILE=cloud
SDKWORK_MANAGER_SERVICE_LAYOUT=split-services
SDKWORK_MANAGER_ENVIRONMENT=production
SDKWORK_MANAGER_PROFILE_ID=cloud.split-services.production

SDKWORK_MANAGER_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:18092
SDKWORK_MANAGER_APPLICATION_PUBLIC_HTTP_URL=http://sdkwork-manager-standalone-gateway:18092

SDKWORK_API_CLOUD_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_MANAGER_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_MANAGER_PLATFORM_API_GATEWAY_AUTOSTART=true
SDKWORK_API_CLOUD_GATEWAY_CONFIG=configs/sdkwork-api-cloud-gateway.manager.production.toml
