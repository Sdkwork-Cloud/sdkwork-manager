{
  "name": "@sdkwork/manager-pc-admin-core",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SDK client provider boundary for SDKWork Manager backend-admin modules.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./sdk": {
      "types": "./src/sdk/index.ts",
      "import": "./src/sdk/index.ts",
      "default": "./src/sdk/index.ts"
    },
    "./modules": {
      "types": "./src/modules/index.ts",
      "import": "./src/modules/index.ts",
      "default": "./src/modules/index.ts"
    },
    "./host": {
      "types": "./src/host/index.ts",
      "import": "./src/host/index.ts",
      "default": "./src/host/index.ts"
    },
    "./session": {
      "types": "./src/session/index.ts",
      "import": "./src/session/index.ts",
      "default": "./src/session/index.ts"
    },
    "./composition": {
      "types": "./src/composition/index.ts",
      "import": "./src/composition/index.ts",
      "default": "./src/composition/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {
    "@sdkwork/manager-backend-sdk": "workspace:*",
    "@sdkwork/payment-backend-sdk": "workspace:*",
    "@sdkwork/payment-service": "workspace:*",
    "@sdkwork/order-backend-sdk": "workspace:*",
    "@sdkwork/order-pc-admin-orders": "workspace:*",
    "@sdkwork/promotion-backend-sdk": "workspace:*",
    "@sdkwork/promotion-service": "workspace:*",
    "@sdkwork/membership-backend-sdk": "workspace:*",
    "@sdkwork/membership-service": "workspace:*",
    "@sdkwork/iam-backend-sdk": "workspace:*",
    "@sdkwork/iam-service": "workspace:*",
    "@sdkwork/manager-client-core": "workspace:*",
    "@sdkwork/manager-pc-core": "workspace:*",
    "sdkwork-drive-pc-admin-core": "workspace:*",
    "sdkwork-drive-pc-core": "workspace:*"
  },
  "sdkwork": {
    "architecture": "pc-admin",
    "surface": "backend-admin",
    "domain": "platform",
    "capability": "admin-core",
    "packageType": "runtime-core",
    "status": "standard"
  }
}
