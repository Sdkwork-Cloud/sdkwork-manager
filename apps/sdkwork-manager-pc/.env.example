# Browser configuration contains public endpoints and non-secret runtime choices only.
# IAM creates and refreshes the authenticated session at runtime; do not add tokens here.

# Local application ingress. IAM app/backend routes are mounted by the Manager Rust assembly.
VITE_SDKWORK_MANAGER_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18092
VITE_SDKWORK_MANAGER_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:18092

# IAM runtime derives its mode from the standard browser lifecycle environment
# and deployment profile. The former IAM-specific keys remain read-only
# compatibility fallbacks and must not be added to new environment files.
VITE_SDKWORK_MANAGER_ENVIRONMENT=development
VITE_SDKWORK_MANAGER_DEPLOYMENT_PROFILE=standalone
VITE_SDKWORK_MANAGER_DEFAULT_LOCALE=zh-CN
VITE_SDKWORK_MANAGER_FALLBACK_LOCALE=en-US

# Optional local-only development prefill. Keep values blank in tracked files.
# VITE_SDKWORK_MANAGER_AUTH_DEV_PREFILL_ENABLED=false
# VITE_SDKWORK_MANAGER_AUTH_DEV_DEFAULT_ACCOUNT=
# VITE_SDKWORK_MANAGER_AUTH_DEV_DEFAULT_PASSWORD=
